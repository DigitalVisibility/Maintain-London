---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Maintain London - Premium Home Renovations in Southwest London">
  <Navigation />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Transforming London's Finest Homes
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          Since 2015, we've been the trusted partner for discerning homeowners in Southwest London and Surrey, delivering exceptional renovations for properties valued at £1m+.
        </p>
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
        <div>
          <h2 class="text-3xl font-extrabold text-gray-900">The Maintain London Journey</h2>
          <p class="mt-4 text-lg text-gray-600">
            Founded in 2015, Maintain London was established with a clear vision: to provide unparalleled renovation services for Southwest London's most distinguished properties. Our journey began with a commitment to exceptional craftsmanship and transparent client relationships.
          </p>
          <p class="mt-4 text-lg text-gray-600">
            Today, we're proud to be the preferred choice for homeowners and design professionals seeking premium renovation services. Our comprehensive project management approach and dedication to using premium materials have established us as leaders in high-end home transformations.
          </p>
        </div>
        <div class="mt-8 lg:mt-0">
          <img 
            src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80"
            alt="Maintain London team collaborating on a renovation project"
            class="rounded-lg shadow-lg"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-gray-900 text-center mb-12">The Maintain London Difference</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Premium Materials</h3>
          <p class="text-gray-600">
            We exclusively use the highest quality materials, installed by our experienced team to ensure lasting beauty and durability in every project.
          </p>
        </div>

        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Comprehensive Management</h3>
          <p class="text-gray-600">
            From pre-construction feasibility to detailed homeowners' packs, we provide end-to-end project management as standard.
          </p>
        </div>

        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Modern Technology</h3>
          <p class="text-gray-600">
            We leverage cutting-edge technology to manage, monitor, and enhance productivity throughout your renovation journey.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Client Focus -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
        <div>
          <h2 class="text-3xl font-extrabold text-gray-900">Who We Serve</h2>
          <p class="mt-4 text-lg text-gray-600">
            We specialize in serving discerning homeowners in Southwest London and Surrey who demand the highest standards in home renovation. Our typical clients own properties valued at £1m+ and appreciate the value of premium craftsmanship.
          </p>
          <p class="mt-4 text-lg text-gray-600">
            We also work closely with interior designers and architects serving this demographic, collaborating to bring ambitious design visions to life with meticulous attention to detail.
          </p>
        </div>
        <div class="mt-8 lg:mt-0 bg-gray-50 p-8 rounded-lg">
          <h3 class="text-xl font-bold text-gray-900 mb-4">Our Commitment to You</h3>
          <ul class="space-y-4">
            <li class="flex items-start">
              <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-600">Transparent and comprehensive quotes</span>
            </li>
            <li class="flex items-start">
              <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-600">Full project management as standard</span>
            </li>
            <li class="flex items-start">
              <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-600">Pre-construction feasibility through to completion</span>
            </li>
            <li class="flex items-start">
              <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-600">Detailed homeowners pack upon completion</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-4xl font-extrabold text-brand-green">500+</div>
          <div class="mt-2 text-gray-600">Projects Completed</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-extrabold text-brand-green">£50M+</div>
          <div class="mt-2 text-gray-600">Project Value</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-extrabold text-brand-green">98%</div>
          <div class="mt-2 text-gray-600">Client Satisfaction</div>
        </div>
        <div class="text-center">
          <div class="text-4xl font-extrabold text-brand-green">25+</div>
          <div class="mt-2 text-gray-600">Expert Team Members</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-gray-900 text-center mb-12">Our Leadership Team</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="relative">
            <img 
              src="https://images.unsplash.com/photo-1560250097-0b93528c311a?auto=format&fit=crop&q=80"
              alt="Tom Dixon - Managing Director"
              class="w-48 h-48 rounded-full mx-auto object-cover"
            />
          </div>
          <h3 class="mt-6 text-xl font-bold text-gray-900">Tom Dixon</h3>
          <p class="text-brand-green">Managing Director</p>
          <p class="mt-2 text-gray-600">
            With extensive experience in luxury renovations, Tom leads our team with expertise and innovation.
          </p>
        </div>

        <div class="text-center">
          <div class="relative">
            <img 
              src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80"
              alt="Head of Design"
              class="w-48 h-48 rounded-full mx-auto object-cover"
            />
          </div>
          <h3 class="mt-6 text-xl font-bold text-gray-900">Head of Design</h3>
          <p class="text-brand-green">Design Director</p>
          <p class="mt-2 text-gray-600">
            Our design team transforms concepts into stunning, functional living spaces.
          </p>
        </div>

        <div class="text-center">
          <div class="relative">
            <img 
              src="https://images.unsplash.com/photo-1552058544-f2b08422138a?auto=format&fit=crop&q=80"
              alt="Operations Director"
              class="w-48 h-48 rounded-full mx-auto object-cover"
            />
          </div>
          <h3 class="mt-6 text-xl font-bold text-gray-900">Operations Director</h3>
          <p class="text-brand-green">Operations</p>
          <p class="mt-2 text-gray-600">
            Ensures every project runs seamlessly, delivering excellence on time and within budget.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-brand-green rounded-lg shadow-xl overflow-hidden">
        <div class="px-6 py-12 md:p-12 text-center">
          <h2 class="text-3xl font-extrabold text-white mb-4">
            Ready to Transform Your Home?
          </h2>
          <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
            Let's discuss how we can bring your vision to life with our premium renovation services.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="inline-flex items-center justify-center px-8 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-brand-green bg-white hover:bg-gray-50 transition-colors duration-200">
              Start Your Project
            </a>
            <a href="/portfolio" class="inline-flex items-center justify-center px-8 py-3 border border-white rounded-md shadow-sm text-base font-medium text-white hover:bg-white/10 transition-colors duration-200">
              View Our Work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>