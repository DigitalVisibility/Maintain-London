---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import PortfolioGallery from '../components/PortfolioGallery.astro';
import BrochurePromo from '../components/BrochurePromo.astro';
import { projects, serviceCategories } from '../data/portfolio-metadata.js';

// Get URL parameters for filtering
const { searchParams } = Astro.url;
const activeProject = searchParams.get('project') || 'all';
const activeCategory = searchParams.get('category') || 'all';

// URL Parameters for filtering
// console.log('URL Parameters:', { activeProject, activeCategory }); // Debug - remove in production

// Get featured project for hero section
const featuredProject = projects.find(p => p.id === 'chesterton-road') || projects[0];
---

<Layout title="Our Portfolio - Maintain London | Premium Home Renovations">
  <Navigation />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Our Signature Projects
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          Discover how we've transformed some of Southwest London's most distinguished properties, creating spaces that inspire and delight.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Featured Project Banner -->
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative h-[500px] rounded-lg overflow-hidden">
        <img
          src={featuredProject.featuredImage}
          alt={`${featuredProject.name} by Maintain London`}
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent">
          <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
            <span class="text-brand-green font-semibold">Featured Project</span>
            <h2 class="text-3xl font-bold mt-2 mb-2">{featuredProject.name}</h2>
            <p class="text-gray-200 mb-4 max-w-xl text-lg">{featuredProject.description}</p>
            <a 
              href={`/portfolio?project=${featuredProject.id}&category=all`}
              class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200"
            >
              View Project Details
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Gallery with Filters -->
  <section class="py-16">
    <PortfolioGallery activeProject={activeProject} activeCategory={activeCategory} />
  </section>

  <!-- Digital Brochure Promo -->
  <section class="py-8 mb-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <BrochurePromo />
    </div>
  </section>

  <Footer />
</Layout>

<script>
  // Handle filtering and image loading on the client side
  document.addEventListener('DOMContentLoaded', () => {
    // Parse URL parameters for filtering
    const urlParams = new URLSearchParams(window.location.search);
    const projectParam = urlParams.get('project') || 'all';
    const categoryParam = urlParams.get('category') || 'all';
    
    // console.log('Client-side params:', { projectParam, categoryParam }); // Debug - remove in production
    
    // Get all portfolio items and filter links
    const portfolioItems = document.querySelectorAll('.portfolio-item');
    const projectLinks = document.querySelectorAll('[data-project-filter]');
    const categoryLinks = document.querySelectorAll('[data-category-filter]');
    
    // Function to filter items based on selected project and category
    function filterItems(project: string, category: string): number {
      let visibleCount = 0;
      
      portfolioItems.forEach(item => {
        const itemProject = item.getAttribute('data-project');
        const itemCategories = JSON.parse(item.getAttribute('data-categories') || '[]');
        
        // Check if item matches both filters
        const projectMatch = project === 'all' || itemProject === project;
        const categoryMatch = category === 'all' || itemCategories.includes(category);
        
        if (projectMatch && categoryMatch) {
          (item as HTMLElement).style.display = 'block';
          visibleCount++;
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
      
      // Show/hide no results message
      const noResultsMessage = document.getElementById('no-results-message');
      if (noResultsMessage) {
        (noResultsMessage as HTMLElement).style.display = visibleCount === 0 ? 'block' : 'none';
      }
      
      return visibleCount;
    }
    
    // Apply initial filtering based on URL parameters
    filterItems(projectParam, categoryParam);
    
    // Highlight active project filter
    projectLinks.forEach(link => {
      const projectId = link.getAttribute('data-project-filter');
      
      // Set initial active state
      if (projectId === projectParam) {
        link.classList.add('bg-brand-green', 'text-white');
        link.classList.remove('bg-gray-200', 'text-gray-800');
      } else {
        link.classList.remove('bg-brand-green', 'text-white');
        link.classList.add('bg-gray-200', 'text-gray-800');
      }
      
      // Add click handler for filtering
      link.addEventListener('click', (e) => {
        e.preventDefault();
        
        // When clicking a project filter, reset the category filter to 'all'
        const newUrl = new URL(window.location.href);
        newUrl.searchParams.set('project', projectId || 'all');
        newUrl.searchParams.set('category', 'all');
        window.history.pushState({}, '', newUrl);
        
        // Update project filter active states
        projectLinks.forEach(l => {
          l.classList.remove('bg-brand-green', 'text-white');
          l.classList.add('bg-gray-200', 'text-gray-800');
        });
        link.classList.add('bg-brand-green', 'text-white');
        link.classList.remove('bg-gray-200', 'text-gray-800');
        
        // Update category filter active states - make "All" active
        categoryLinks.forEach(l => {
          const catId = l.getAttribute('data-category-filter') || 'all';
          if (catId === 'all') {
            l.classList.add('bg-brand-green', 'text-white');
            l.classList.remove('bg-gray-200', 'text-gray-800');
          } else {
            l.classList.remove('bg-brand-green', 'text-white');
            l.classList.add('bg-gray-200', 'text-gray-800');
          }
        });
        
        // Filter items
        filterItems(projectId || 'all', 'all');
      });
    });
    
    // Highlight active category filter
    categoryLinks.forEach(link => {
      const categoryId = link.getAttribute('data-category-filter');
      
      // Set initial active state
      if (categoryId === categoryParam) {
        link.classList.add('bg-brand-green', 'text-white');
        link.classList.remove('bg-gray-200', 'text-gray-800');
      } else {
        link.classList.remove('bg-brand-green', 'text-white');
        link.classList.add('bg-gray-200', 'text-gray-800');
      }
      
      // Add click handler for filtering
      link.addEventListener('click', (e) => {
        e.preventDefault();
        
        // When clicking a category filter, reset the project filter to 'all'
        const newUrl = new URL(window.location.href);
        newUrl.searchParams.set('project', 'all');
        newUrl.searchParams.set('category', categoryId || 'all');
        window.history.pushState({}, '', newUrl);
        
        // Update category filter active states
        categoryLinks.forEach(l => {
          l.classList.remove('bg-brand-green', 'text-white');
          l.classList.add('bg-gray-200', 'text-gray-800');
        });
        link.classList.add('bg-brand-green', 'text-white');
        link.classList.remove('bg-gray-200', 'text-gray-800');
        
        // Update project filter active states - make "All" active
        projectLinks.forEach(l => {
          const projId = l.getAttribute('data-project-filter') || 'all';
          if (projId === 'all') {
            l.classList.add('bg-brand-green', 'text-white');
            l.classList.remove('bg-gray-200', 'text-gray-800');
          } else {
            l.classList.remove('bg-brand-green', 'text-white');
            l.classList.add('bg-gray-200', 'text-gray-800');
          }
        });
        
        // Filter items
        filterItems('all', categoryId || 'all');
      });
    });
    
    // Lazy load images for better performance
    const lazyImages = document.querySelectorAll('img');
    
    if ('IntersectionObserver' in window) {
      const imageObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const image = entry.target as HTMLImageElement;
            image.classList.add('fade-in');
            imageObserver.unobserve(image);
          }
        });
      });
      
      lazyImages.forEach(image => {
        imageObserver.observe(image);
      });
    }
  });
</script>

<style>
  img {
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
  }
  
  img.fade-in {
    opacity: 1;
  }
</style>
