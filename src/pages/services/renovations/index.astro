---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout title="Home Renovations - Maintain London | Premium Property Transformations">
  <Navigation />

  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Transforming London's Finest Properties
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          Crafting exceptional living spaces through meticulous renovation and unparalleled attention to detail.
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center mb-16">
        <div>
          <span class="text-brand-green font-semibold">Premium Home Renovations</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">Elevating London's Properties Through Expert Craftsmanship</h2>
          <p class="text-lg text-gray-600 mb-8">
            With over 500 successful renovations completed across Southwest London and Surrey, we've mastered the art of transforming high-end properties. Our signature approach combines traditional craftsmanship with innovative design solutions, ensuring each renovation not only meets but exceeds the expectations of London's most discerning homeowners.
          </p>
          <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
            <h3 class="text-xl font-bold text-gray-900 mb-4">Why Choose Maintain London</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">15+ Years of Excellence</span>
                  <p class="text-gray-600 mt-1">Our master craftsmen bring decades of experience in luxury renovations</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Comprehensive Project Management</span>
                  <p class="text-gray-600 mt-1">End-to-end service with dedicated project managers and real-time updates</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Premium Materials</span>
                  <p class="text-gray-600 mt-1">Direct relationships with Europe's finest material suppliers</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="mt-8">
            <a href="/quote/" class="inline-flex items-center justify-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-green hover:bg-brand-green/90">
              Start Your Renovation Journey
            </a>
          </div>
        </div>
        <div class="mt-8 lg:mt-0">
          <img 
            src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80"
            alt="Luxury home renovation in Southwest London"
            class="rounded-lg shadow-lg"
          />
          <p class="mt-4 text-sm text-gray-500 italic">Recently completed renovation in Richmond, featuring our signature blend of period restoration and modern luxury</p>
        </div>
      </div>

      <!-- Our Renovation Process -->
      <div class="py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Our Renovation Process</h2>
          <p class="mt-4 text-xl text-gray-600">
            A refined approach that ensures exceptional results, every time
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <span class="text-2xl font-bold text-brand-green">1</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Initial Consultation</h3>
            <p class="text-gray-600">
              In-depth discussion of your vision, requirements, and budget. We provide initial guidance and explore possibilities for your space.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <span class="text-2xl font-bold text-brand-green">2</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Design & Planning</h3>
            <p class="text-gray-600">
              Detailed designs, 3D visualizations, and comprehensive project plans. We handle all necessary permissions and approvals.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <span class="text-2xl font-bold text-brand-green">3</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Expert Execution</h3>
            <p class="text-gray-600">
              Our master craftsmen bring your vision to life with precision and care, ensuring every detail meets our exacting standards.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <span class="text-2xl font-bold text-brand-green">4</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Quality Assurance</h3>
            <p class="text-gray-600">
              Rigorous quality checks and detailed handover process, including comprehensive documentation and aftercare support.
            </p>
          </div>
        </div>
      </div>

      <!-- Featured Projects -->
      <div class="py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Featured Renovations</h2>
          <p class="mt-4 text-xl text-gray-600">
            Discover how we've transformed some of London's finest homes
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="group relative overflow-hidden rounded-lg">
            <img
              src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80"
              alt="Richmond Victorian Renovation"
              class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <h3 class="text-xl font-bold text-white">Richmond Victorian</h3>
                <p class="text-gray-200 mt-2">Complete renovation with period feature restoration</p>
                <a href="/portfolio/richmond-victorian/" class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200 mt-4">
                  View Project
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <div class="group relative overflow-hidden rounded-lg">
            <img
              src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&q=80"
              alt="Chelsea Townhouse Renovation"
              class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <h3 class="text-xl font-bold text-white">Chelsea Townhouse</h3>
                <p class="text-gray-200 mt-2">Luxury renovation with smart home integration</p>
                <a href="/portfolio/chelsea-townhouse/" class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200 mt-4">
                  View Project
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <div class="group relative overflow-hidden rounded-lg">
            <img
              src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?auto=format&fit=crop&q=80"
              alt="Hampstead Garden Property"
              class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <h3 class="text-xl font-bold text-white">Hampstead Garden</h3>
                <p class="text-gray-200 mt-2">Modern transformation with sustainable features</p>
                <a href="/portfolio/hampstead-garden/" class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200 mt-4">
                  View Project
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="text-center mt-12">
          <a href="/portfolio/" class="inline-flex items-center justify-center px-8 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-green hover:bg-brand-green/90">
            View All Projects
          </a>
        </div>
      </div>

      <!-- Related Services -->
      <div class="py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Complementary Services</h2>
          <p class="mt-4 text-xl text-gray-600">
            Explore our full range of renovation services
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Kitchen Design</h3>
            <p class="text-gray-600 mb-6">
              Transform your kitchen into a stunning, functional space with our bespoke design service.
            </p>
            <a href="/services/kitchens/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Bathroom Design</h3>
            <p class="text-gray-600 mb-6">
              Create your perfect bathroom sanctuary with our luxury design and installation service.
            </p>
            <a href="/services/bathrooms/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">House Extensions</h3>
            <p class="text-gray-600 mb-6">
              Expand your living space with our expertly designed and built home extensions.
            </p>
            <a href="/services/extensions/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-brand-green rounded-lg shadow-xl overflow-hidden">
        <div class="px-6 py-12 md:p-12 text-center">
          <h2 class="text-3xl font-extrabold text-white mb-4">
            Ready to Transform Your Home?
          </h2>
          <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
            Join the growing number of Southwest London homeowners who've trusted us to create their dream spaces. Book a consultation today and discover the possibilities for your home.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact/" class="inline-flex items-center justify-center px-8 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-brand-green bg-white hover:bg-gray-50 transition-colors duration-200">
              Book a Consultation
            </a>
            <a href="/portfolio/" class="inline-flex items-center justify-center px-8 py-3 border border-white rounded-md shadow-sm text-base font-medium text-white hover:bg-white/10 transition-colors duration-200">
              View Our Portfolio
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>