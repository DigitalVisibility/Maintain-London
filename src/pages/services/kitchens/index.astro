---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Luxury Kitchen Design & Installation",
  "description": "Bespoke luxury kitchen design and installation in Southwest London and Surrey. Handcrafted cabinetry, smart home integration, 3D visualisation, and premium European materials. 150+ luxury kitchens delivered.",
  "provider": { "@id": "https://maintainlondon.co.uk/#organization" },
  "areaServed": { "@type": "AdministrativeArea", "name": "Southwest London and Surrey" },
  "serviceType": "Kitchen Design and Installation",
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "GBP",
    "lowPrice": "50000",
    "highPrice": "150000"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Kitchen Design Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bespoke Kitchen Design with 3D Visualisation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Handcrafted Custom Cabinetry" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Smart Home Kitchen Integration" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Premium Appliance Supply & Installation" } }
    ]
  }
});
---

<Layout
  title="Luxury Kitchen Design London | Bespoke Kitchens from £50k"
  description="Bespoke luxury kitchen design and installation in Southwest London. Handcrafted cabinetry, smart home integration, 3D visualisation. 150+ kitchens delivered. Call 020 3886 2023."
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Services", url: "/services" },
    { name: "Kitchen Design", url: "/services/kitchens" }
  ]}
  schema={serviceSchema}
>
  <Navigation />

  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Bespoke Kitchen Design & Installation
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          Creating exceptional kitchens that blend innovative design, premium materials, and smart technology for London's finest homes.
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Design Philosophy -->
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center mb-16">
        <div>
          <span class="text-brand-green font-semibold">Our Design Philosophy</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">Crafting the Heart of Your Home</h2>
          <p class="text-lg text-gray-600 mb-8">
            With over 150 luxury kitchens delivered across Southwest London, we understand that a kitchen is more than just a cooking space—it's where life happens. Our innovative approach combines timeless design principles with cutting-edge technology, creating spaces that are both beautiful and highly functional.
          </p>
          <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
            <h3 class="text-xl font-bold text-gray-900 mb-4">The Maintain London Difference</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Bespoke Design Service</span>
                  <p class="text-gray-600 mt-1">Every kitchen is uniquely designed to reflect your lifestyle and preferences</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Premium European Materials</span>
                  <p class="text-gray-600 mt-1">Exclusive partnerships with leading European manufacturers</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Smart Integration</span>
                  <p class="text-gray-600 mt-1">Seamless incorporation of the latest smart home technologies</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
        <div class="mt-8 lg:mt-0">
          <img 
            src="https://images.unsplash.com/photo-1556911220-bff31c812dba?auto=format&fit=crop&q=80"
            alt="Luxury kitchen design in Chelsea"
            class="rounded-lg shadow-lg"
          />
          <p class="mt-4 text-sm text-gray-500 italic">Award-winning kitchen featuring handcrafted cabinetry and smart home integration</p>
        </div>
      </div>

      <!-- Design Process -->
      <div class="py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Our Design Process</h2>
          <p class="mt-4 text-xl text-gray-600">
            A collaborative journey from concept to completion
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <span class="text-2xl font-bold text-brand-green">1</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Discovery</h3>
            <p class="text-gray-600">
              In-depth consultation to understand your cooking style, entertainment needs, and aesthetic preferences. We analyze your space and discuss possibilities.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <span class="text-2xl font-bold text-brand-green">2</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Design Development</h3>
            <p class="text-gray-600">
              Creation of detailed 3D visualizations and material selections. Experience your new kitchen through our virtual reality platform.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <span class="text-2xl font-bold text-brand-green">3</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Craftsmanship</h3>
            <p class="text-gray-600">
              Expert installation by our master craftsmen. Every detail is executed with precision and care, ensuring perfection.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <span class="text-2xl font-bold text-brand-green">4</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Handover</h3>
            <p class="text-gray-600">
              Comprehensive demonstration of all features, including smart systems. Detailed care guide and ongoing support provided.
            </p>
          </div>
        </div>
      </div>

      <!-- Innovation Section -->
      <div class="py-16">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <div class="order-2">
            <span class="text-brand-green font-semibold">Innovation & Technology</span>
            <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">Smart Kitchen Solutions</h2>
            <p class="text-lg text-gray-600 mb-8">
              We're revolutionizing kitchen design with our upcoming smart kitchen planning application. This AI-powered tool will help visualize and optimize your kitchen layout, while our client portal ensures transparent communication throughout your project.
            </p>
            <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
              <h3 class="text-xl font-bold text-gray-900 mb-4">Smart Features</h3>
              <ul class="space-y-4">
                <li class="flex items-start">
                  <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <div>
                    <span class="font-semibold">Integrated Appliance Control</span>
                    <p class="text-gray-600 mt-1">Manage all kitchen appliances from a single interface</p>
                  </div>
                </li>
                <li class="flex items-start">
                  <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <div>
                    <span class="font-semibold">Smart Storage Solutions</span>
                    <p class="text-gray-600 mt-1">Automated inventory management and shopping list generation</p>
                  </div>
                </li>
                <li class="flex items-start">
                  <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <div>
                    <span class="font-semibold">Voice Control</span>
                    <p class="text-gray-600 mt-1">Hands-free operation of lighting, appliances, and more</p>
                  </div>
                </li>
              </ul>
            </div>
          </div>
          <div class="order-1 mt-8 lg:mt-0">
            <img 
              src="https://images.unsplash.com/photo-1600585154526-990dced4db0d?auto=format&fit=crop&q=80"
              alt="Smart kitchen technology integration"
              class="rounded-lg shadow-lg"
            />
          </div>
        </div>
      </div>

      <!-- Materials Section -->
      <div class="py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Premium Materials</h2>
          <p class="mt-4 text-xl text-gray-600">
            Only the finest materials make it into our kitchens
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Luxury Surfaces</h3>
            <ul class="text-gray-600 space-y-2">
              <li>• Italian marble</li>
              <li>• Premium quartz</li>
              <li>• Sustainable hardwoods</li>
              <li>• Nano-tech surfaces</li>
            </ul>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Cabinetry</h3>
            <ul class="text-gray-600 space-y-2">
              <li>• Handcrafted units</li>
              <li>• German mechanisms</li>
              <li>• Custom finishes</li>
              <li>• Soft-close standard</li>
            </ul>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Lighting</h3>
            <ul class="text-gray-600 space-y-2">
              <li>• LED systems</li>
              <li>• Smart controls</li>
              <li>• Task lighting</li>
              <li>• Ambient options</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Related Services -->
      <div class="py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Complete Home Transformation</h2>
          <p class="mt-4 text-xl text-gray-600">
            Explore our other renovation services
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Complete Renovations</h3>
            <p class="text-gray-600 mb-6">
              Transform your entire home with our comprehensive renovation service.
            </p>
            <a href="/services/renovations/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Bathroom Design</h3>
            <p class="text-gray-600 mb-6">
              Create your perfect bathroom sanctuary with our luxury design service.
            </p>
            <a href="/services/bathrooms/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">House Extensions</h3>
            <p class="text-gray-600 mb-6">
              Expand your living space with our expertly designed extensions.
            </p>
            <a href="/services/extensions/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-brand-green rounded-lg shadow-xl overflow-hidden">
        <div class="px-6 py-12 md:p-12 text-center">
          <h2 class="text-3xl font-extrabold text-white mb-4">
            Ready to Create Your Dream Kitchen?
          </h2>
          <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
            Let's discuss how we can transform your kitchen into a stunning space that perfectly suits your lifestyle.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact/" class="inline-flex items-center justify-center px-8 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-brand-green bg-white hover:bg-gray-50 transition-colors duration-200">
              Book a Consultation
            </a>
            <a href="/portfolio/" class="inline-flex items-center justify-center px-8 py-3 border border-white rounded-md shadow-sm text-base font-medium text-white hover:bg-white/10 transition-colors duration-200">
              View Our Portfolio
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>