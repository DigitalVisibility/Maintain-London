---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout title="Luxury Bathroom Design London | Maintain London">
  <Navigation />

  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Luxury Bathroom Design & Installation
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          Creating spa-inspired sanctuaries that blend sophisticated design with cutting-edge wellness technology.
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Design Philosophy -->
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center mb-16">
        <div>
          <span class="text-brand-green font-semibold">Our Design Philosophy</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">Creating Your Personal Wellness Retreat</h2>
          <p class="text-lg text-gray-600 mb-8">
            Drawing inspiration from the world's finest spas and boutique hotels, our bathroom designs transcend traditional functionality. We integrate advanced wellness technologies with luxurious materials to create spaces that promote relaxation and rejuvenation.
          </p>
          <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
            <h3 class="text-xl font-bold text-gray-900 mb-4">The Maintain London Approach</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Wellness-First Design</span>
                  <p class="text-gray-600 mt-1">Incorporating chromotherapy, aromatherapy, and smart climate control</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Space Optimization</span>
                  <p class="text-gray-600 mt-1">Innovative storage solutions and layout planning for any space</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Sustainable Luxury</span>
                  <p class="text-gray-600 mt-1">Water-saving technology that doesn't compromise on performance</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
        <div class="mt-8 lg:mt-0">
          <img 
            src="https://images.unsplash.com/photo-1620626011761-996317b8d101?auto=format&fit=crop&q=80"
            alt="Luxury bathroom design in Hampstead"
            class="rounded-lg shadow-lg"
          />
          <p class="mt-4 text-sm text-gray-500 italic">Recently completed spa-inspired bathroom featuring Italian marble and smart wellness technology</p>
        </div>
      </div>

      <!-- Wellness Technology -->
      <div class="py-16">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <div class="order-2">
            <span class="text-brand-green font-semibold">Smart Wellness Integration</span>
            <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">The Future of Bathroom Technology</h2>
            <p class="text-lg text-gray-600 mb-8">
              Our upcoming smart bathroom design application will revolutionize how you experience your space. Using AI-powered technology, we're creating bathrooms that adapt to your wellness routines and preferences.
            </p>
            <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
              <h3 class="text-xl font-bold text-gray-900 mb-4">Smart Features</h3>
              <ul class="space-y-4">
                <li class="flex items-start">
                  <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <div>
                    <span class="font-semibold">Personalized Climate Control</span>
                    <p class="text-gray-600 mt-1">Automated temperature and humidity management</p>
                  </div>
                </li>
                <li class="flex items-start">
                  <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <div>
                    <span class="font-semibold">Chromotherapy Lighting</span>
                    <p class="text-gray-600 mt-1">Color-changing LED systems for enhanced wellbeing</p>
                  </div>
                </li>
                <li class="flex items-start">
                  <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <div>
                    <span class="font-semibold">Digital Shower Controls</span>
                    <p class="text-gray-600 mt-1">Precise temperature and flow control via smartphone</p>
                  </div>
                </li>
              </ul>
            </div>
          </div>
          <div class="order-1 mt-8 lg:mt-0">
            <img 
              src="https://images.unsplash.com/photo-1620626011761-996317b8d101?auto=format&fit=crop&q=80"
              alt="Smart bathroom technology integration"
              class="rounded-lg shadow-lg"
            />
          </div>
        </div>
      </div>

      <!-- Materials Section -->
      <div class="py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Premium Materials</h2>
          <p class="mt-4 text-xl text-gray-600">
            Curated selection of the world's finest bathroom materials
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Natural Stone</h3>
            <ul class="text-gray-600 space-y-2">
              <li>• Italian marble</li>
              <li>• Greek travertine</li>
              <li>• Volcanic basalt</li>
              <li>• Natural slate</li>
            </ul>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Premium Fixtures</h3>
            <ul class="text-gray-600 space-y-2">
              <li>• Swiss taps</li>
              <li>• German showers</li>
              <li>• Japanese toilets</li>
              <li>• Italian basins</li>
            </ul>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Wellness Features</h3>
            <ul class="text-gray-600 space-y-2">
              <li>• Steam systems</li>
              <li>• Aromatherapy units</li>
              <li>• LED therapy</li>
              <li>• Sound systems</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Related Services -->
      <div class="py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Complete Home Transformation</h2>
          <p class="mt-4 text-xl text-gray-600">
            Explore our other renovation services
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Kitchen Design</h3>
            <p class="text-gray-600 mb-6">
              Transform your kitchen into a stunning, functional space with our bespoke design service.
            </p>
            <a href="/services/kitchens/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Complete Renovations</h3>
            <p class="text-gray-600 mb-6">
              Transform your entire home with our comprehensive renovation service.
            </p>
            <a href="/services/renovations/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">House Extensions</h3>
            <p class="text-gray-600 mb-6">
              Expand your living space with our expertly designed extensions.
            </p>
            <a href="/services/extensions/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-brand-green rounded-lg shadow-xl overflow-hidden">
        <div class="px-6 py-12 md:p-12 text-center">
          <h2 class="text-3xl font-extrabold text-white mb-4">
            Ready to Create Your Perfect Bathroom?
          </h2>
          <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
            Let's discuss how we can transform your bathroom into a luxurious wellness retreat.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact/" class="inline-flex items-center justify-center px-8 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-brand-green bg-white hover:bg-gray-50 transition-colors duration-200">
              Book a Consultation
            </a>
            <a href="/portfolio/" class="inline-flex items-center justify-center px-8 py-3 border border-white rounded-md shadow-sm text-base font-medium text-white hover:bg-white/10 transition-colors duration-200">
              View Our Portfolio
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>