---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Architectural House Extensions",
  "description": "Architectural home extensions in Southwest London and Surrey. Seamless integration with existing properties, full planning permission management. 75+ successful extensions completed.",
  "provider": { "@id": "https://maintainlondon.co.uk/#organization" },
  "areaServed": { "@type": "AdministrativeArea", "name": "Southwest London and Surrey" },
  "serviceType": "House Extension",
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "GBP",
    "lowPrice": "100000",
    "highPrice": "500000"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Extension Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Single & Double Storey Extensions" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Glass & Contemporary Extensions" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Planning Permission Management" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Structural Engineering" } }
    ]
  }
});
---

<Layout
  title="House Extensions London | From £100k | Planning to Completion"
  description="Architectural house extensions in Southwest London. 75+ completed, full planning permission management, 10-year warranty. From £100k. Call 020 3886 2023."
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Services", url: "/services" },
    { name: "House Extensions", url: "/services/extensions" }
  ]}
  schema={serviceSchema}
>
  <Navigation />

  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Architectural Home Extensions
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          Seamlessly expanding London's finest homes with innovative design and precision engineering.
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Design Philosophy -->
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center mb-16">
        <div>
          <span class="text-brand-green font-semibold">Our Extension Expertise</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">Expanding Possibilities Through Architectural Innovation</h2>
          <p class="text-lg text-gray-600 mb-8">
            With over 75 successful extensions completed across Southwest London, we've mastered the art of seamlessly integrating new spaces with existing architecture. Our recent Chelsea project added 40% more living space while increasing the property's value by £750,000.
          </p>
          <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
            <h3 class="text-xl font-bold text-gray-900 mb-4">The Maintain London Advantage</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Planning Expertise</span>
                  <p class="text-gray-600 mt-1">100% success rate with planning applications in conservation areas</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Structural Innovation</span>
                  <p class="text-gray-600 mt-1">Advanced engineering solutions for complex extensions</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Sustainable Design</span>
                  <p class="text-gray-600 mt-1">Energy-efficient solutions that exceed building regulations</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
        <div class="mt-8 lg:mt-0">
          <img 
            src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&q=80"
            alt="Modern glass extension in Richmond"
            class="rounded-lg shadow-lg"
          />
          <p class="mt-4 text-sm text-gray-500 italic">Award-winning glass extension featuring thermal glass and automated climate control</p>
        </div>
      </div>

      <!-- Extension Types -->
      <div class="py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Extension Solutions</h2>
          <p class="mt-4 text-xl text-gray-600">
            Tailored extensions to suit your property and lifestyle
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Single-Storey Extensions</h3>
            <ul class="text-gray-600 space-y-2">
              <li>• Kitchen extensions</li>
              <li>• Garden rooms</li>
              <li>• Orangeries</li>
              <li>• Living space expansion</li>
            </ul>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Double-Storey Extensions</h3>
            <ul class="text-gray-600 space-y-2">
              <li>• Master suites</li>
              <li>• Family rooms</li>
              <li>• Multi-room additions</li>
              <li>• Vertical expansions</li>
            </ul>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Glass Extensions</h3>
            <ul class="text-gray-600 space-y-2">
              <li>• Frameless designs</li>
              <li>• Winter gardens</li>
              <li>• Structural glass</li>
              <li>• Hybrid solutions</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Planning & Technology -->
      <div class="py-16">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <div class="order-2">
            <span class="text-brand-green font-semibold">Innovation in Planning</span>
            <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">Advanced Planning Technology</h2>
            <p class="text-lg text-gray-600 mb-8">
              Our upcoming extension planning application revolutionizes the design process. Using AI and augmented reality, clients can visualize their extension in real-time, exploring different configurations and materials before construction begins.
            </p>
            <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
              <h3 class="text-xl font-bold text-gray-900 mb-4">Digital Planning Features</h3>
              <ul class="space-y-4">
                <li class="flex items-start">
                  <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <div>
                    <span class="font-semibold">3D Visualization</span>
                    <p class="text-gray-600 mt-1">Real-time rendering of your extension in context</p>
                  </div>
                </li>
                <li class="flex items-start">
                  <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <div>
                    <span class="font-semibold">Light Analysis</span>
                    <p class="text-gray-600 mt-1">Seasonal daylight simulation for optimal design</p>
                  </div>
                </li>
                <li class="flex items-start">
                  <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <div>
                    <span class="font-semibold">Planning Compliance</span>
                    <p class="text-gray-600 mt-1">Automated checks against local planning regulations</p>
                  </div>
                </li>
              </ul>
            </div>
          </div>
          <div class="order-1 mt-8 lg:mt-0">
            <img 
              src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&q=80"
              alt="3D visualization of home extension"
              class="rounded-lg shadow-lg"
            />
          </div>
        </div>
      </div>

      <!-- Related Services -->
      <div class="py-16">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Complete Home Transformation</h2>
          <p class="mt-4 text-xl text-gray-600">
            Explore our other renovation services
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Kitchen Design</h3>
            <p class="text-gray-600 mb-6">
              Transform your kitchen into a stunning, functional space with our bespoke design service.
            </p>
            <a href="/services/kitchens/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Bathroom Design</h3>
            <p class="text-gray-600 mb-6">
              Create your perfect bathroom sanctuary with our luxury design service.
            </p>
            <a href="/services/bathrooms/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Complete Renovations</h3>
            <p class="text-gray-600 mb-6">
              Transform your entire home with our comprehensive renovation service.
            </p>
            <a href="/services/renovations/" class="inline-flex items-center text-brand-green hover:text-brand-green/80">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-brand-green rounded-lg shadow-xl overflow-hidden">
        <div class="px-6 py-12 md:p-12 text-center">
          <h2 class="text-3xl font-extrabold text-white mb-4">
            Ready to Expand Your Living Space?
          </h2>
          <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
            Let's discuss how we can create the perfect extension for your home, combining innovative design with practical living space.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact/" class="inline-flex items-center justify-center px-8 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-brand-green bg-white hover:bg-gray-50 transition-colors duration-200">
              Book a Consultation
            </a>
            <a href="/portfolio/" class="inline-flex items-center justify-center px-8 py-3 border border-white rounded-md shadow-sm text-base font-medium text-white hover:bg-white/10 transition-colors duration-200">
              View Our Portfolio
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>