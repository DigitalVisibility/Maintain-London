---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import PortfolioGallery from '../components/PortfolioGallery.astro';
import { projects, serviceCategories } from '../data/portfolio-metadata.js';

// Get URL parameters for filtering
const { searchParams } = Astro.url;
const activeProject = searchParams.get('project') || 'all';
const activeCategory = searchParams.get('category') || 'all';

// Get featured project for hero section
const featuredProject = projects.find(p => p.id === 'chesterton-road') || projects[0];
---

<Layout title="Our Portfolio - Maintain London | Premium Home Renovations">
  <Navigation />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Our Signature Projects
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          Discover how we've transformed some of Southwest London's most distinguished properties, creating spaces that inspire and delight.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Featured Project Banner -->
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative h-[500px] rounded-lg overflow-hidden">
        <img
          src={featuredProject.featuredImage}
          alt={`${featuredProject.name} by Maintain London`}
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent">
          <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
            <span class="text-brand-green font-semibold">Featured Project</span>
            <h2 class="text-3xl font-bold mt-2 mb-2">{featuredProject.name}</h2>
            <p class="text-gray-200 mb-4 max-w-xl text-lg">{featuredProject.description}</p>
            <a 
              href={`/portfolio?project=${featuredProject.id}&category=all`}
              class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200"
            >
              View Project Details
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Gallery with Filters -->
  <section class="py-16">
    <PortfolioGallery activeProject={activeProject} activeCategory={activeCategory} />
                    <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Kitchen Project 2 -->
        <div class="group relative project-item" data-category="kitchen">
          <div class="relative h-[400px] rounded-lg overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80"
              alt="Luxury Kitchen Design"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <span class="text-brand-green font-semibold">Kitchen Design</span>
                <h3 class="text-xl font-bold text-white mt-2 mb-2">Luxury Open Plan</h3>
                <p class="text-gray-200 mb-4">Open-concept kitchen with island and premium finishes</p>
                <a href="/portfolio/luxury-kitchen" class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200">
                  View Project
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Bathroom Project 2 -->
        <div class="group relative project-item" data-category="bathroom">
          <div class="relative h-[400px] rounded-lg overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1620626011761-996317b8d101?auto=format&fit=crop&q=80"
              alt="Modern Bathroom Design"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <span class="text-brand-green font-semibold">Bathroom Design</span>
                <h3 class="text-xl font-bold text-white mt-2 mb-2">Contemporary Bathroom</h3>
                <p class="text-gray-200 mb-4">Modern bathroom with premium fixtures and finishes</p>
                <a href="/portfolio/modern-bathroom" class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200">
                  View Project
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Load More Button -->
      <div class="text-center mt-16">
        <button id="load-more" class="inline-flex items-center justify-center px-8 py-3 border border-gray-300 rounded-md shadow-sm text-base font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors duration-200">
          Load More Projects
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  // Lazy load images for better performance
  document.addEventListener('DOMContentLoaded', () => {
    const lazyImages = document.querySelectorAll('img');
    
    if ('IntersectionObserver' in window) {
      const imageObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const image = entry.target as HTMLImageElement;
            image.classList.add('fade-in');
            imageObserver.unobserve(image);
          }
        });
      });
      
      lazyImages.forEach(image => {
        imageObserver.observe(image);
      });
    }
  });
</script>

<style>
  img {
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
  }
  
  img.fade-in {
    opacity: 1;
  }
</style>