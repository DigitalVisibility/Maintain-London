---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Home Renovation Services London | Kitchens, Bathrooms & Extensions"
  description="Explore Maintain London's premium renovation services: luxury kitchens (£50k-£150k), bathrooms (£25k-£75k), house extensions (£100k-£500k+) and full renovations in Southwest London."
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Services", url: "/services" }
  ]}
>
  <Navigation />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Crafting London's Finest Homes
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          For over 15 years, we've transformed Southwest London's most distinguished properties, delivering exceptional craftsmanship and unparalleled attention to detail in every project.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Home Renovation</h3>
          <p class="text-gray-600 mb-4">Transforming London's finest properties with our signature blend of luxury craftsmanship and innovative design.</p>
          <a href="#home-renovation" class="text-brand-green hover:text-brand-green/80">Discover our approach →</a>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Kitchen Design</h3>
          <p class="text-gray-600 mb-4">Creating the heart of your home with bespoke designs that blend functionality with timeless elegance.</p>
          <a href="#kitchen-design" class="text-brand-green hover:text-brand-green/80">Explore our kitchens →</a>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Bathroom Design</h3>
          <p class="text-gray-600 mb-4">Crafting luxurious sanctuaries that combine spa-like tranquility with practical sophistication.</p>
          <a href="#bathroom-design" class="text-brand-green hover:text-brand-green/80">View our bathrooms →</a>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">House Extensions</h3>
          <p class="text-gray-600 mb-4">Seamlessly expanding your living space while enhancing your property's architectural appeal and value.</p>
          <a href="#house-extensions" class="text-brand-green hover:text-brand-green/80">Learn about extensions →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Home Renovation Section -->
  <section id="home-renovation" class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
        <div>
          <span class="text-brand-green font-semibold">Complete Home Transformations</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">The Art of Transforming Period Properties into Contemporary Living Spaces</h2>
          <p class="text-lg text-gray-600 mb-8">
            Having renovated over 200 premium properties across Southwest London, we understand the delicate balance between preserving period charm and introducing modern luxury. Our recent Richmond project saw a Victorian property's value increase by 40% through thoughtful modernization while maintaining its original character.
          </p>
          <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
            <h3 class="text-xl font-bold text-gray-900 mb-4">Why Our Renovations Stand Apart</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">15+ Years of Premium Craftsmanship</span>
                  <p class="text-gray-600 mt-1">Our master craftsmen average 15+ years of experience in high-end renovations</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Dedicated Project Management</span>
                  <p class="text-gray-600 mt-1">Your personal project manager oversees every detail, ensuring seamless execution</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Premium Material Sourcing</span>
                  <p class="text-gray-600 mt-1">Direct relationships with Europe's finest material suppliers ensure exceptional quality</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Comprehensive Warranty</span>
                  <p class="text-gray-600 mt-1">10-year structural warranty and 2-year craftsmanship guarantee for peace of mind</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="mt-8">
            <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-green hover:bg-brand-green/90">
              Start Your Renovation Journey
            </a>
          </div>
        </div>
        <div class="mt-8 lg:mt-0">
          <img 
            src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80&w=800"
            width="800"
            height="534"
            loading="lazy"
            decoding="async"
            alt="Luxury home renovation project in Southwest London"
            class="rounded-lg shadow-lg"
          />
          <p class="mt-4 text-sm text-gray-500 italic">Recently completed renovation in Richmond, featuring our signature blend of period restoration and modern luxury</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Kitchen Design Section -->
  <section id="kitchen-design" class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
        <div class="order-2 lg:order-1">
          <img 
            src="https://images.unsplash.com/photo-1556911220-bff31c812dba?auto=format&fit=crop&q=80&w=800"
            width="800"
            height="534"
            loading="lazy"
            decoding="async"
            alt="Bespoke kitchen design in Chelsea"
            class="rounded-lg shadow-lg"
          />
          <p class="mt-4 text-sm text-gray-500 italic">Award-winning kitchen design featuring handcrafted cabinetry and smart home integration</p>
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-brand-green font-semibold">Bespoke Kitchen Design</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">Where Culinary Excellence Meets Architectural Beauty</h2>
          <p class="text-lg text-gray-600 mb-8">
            Our kitchens are more than cooking spaces; they're the soul of your home. With over 150 luxury kitchens delivered across London, we've mastered the art of creating spaces that inspire culinary creativity while serving as sophisticated entertainment hubs.
          </p>
          <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
            <h3 class="text-xl font-bold text-gray-900 mb-4">The Maintain London Kitchen Experience</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Bespoke Design Process</span>
                  <p class="text-gray-600 mt-1">Personalized design journey with 3D visualization and material sampling</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Handcrafted Excellence</span>
                  <p class="text-gray-600 mt-1">Custom cabinetry handmade by master craftsmen in our London workshop</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Smart Integration</span>
                  <p class="text-gray-600 mt-1">Seamless incorporation of high-end appliances and smart home technology</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Lifetime Support</span>
                  <p class="text-gray-600 mt-1">Ongoing maintenance and support for your kitchen's longevity</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="mt-8">
            <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-green hover:bg-brand-green/90">
              Design Your Dream Kitchen
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bathroom Design Section -->
  <section id="bathroom-design" class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
        <div>
          <span class="text-brand-green font-semibold">Luxury Bathroom Design</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">Creating Your Personal Sanctuary of Wellness and Luxury</h2>
          <p class="text-lg text-gray-600 mb-8">
            Drawing inspiration from the world's finest spas and hotels, our bathroom designs combine innovative technology with timeless luxury. Our recent Hampstead project showcases how we transform ordinary spaces into extraordinary private retreats.
          </p>
          <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
            <h3 class="text-xl font-bold text-gray-900 mb-4">Signature Bathroom Features</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Wellness Integration</span>
                  <p class="text-gray-600 mt-1">Smart lighting, chromotherapy, and advanced climate control systems</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Bespoke Stonework</span>
                  <p class="text-gray-600 mt-1">Hand-selected marble and natural stone from Italian quarries</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Innovative Storage</span>
                  <p class="text-gray-600 mt-1">Custom-designed solutions that maximize space without compromising style</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Sustainable Luxury</span>
                  <p class="text-gray-600 mt-1">Water-saving fixtures that don't compromise on performance</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="mt-8">
            <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-green hover:bg-brand-green/90">
              Transform Your Bathroom
            </a>
          </div>
        </div>
        <div class="mt-8 lg:mt-0">
          <img 
            src="https://images.unsplash.com/photo-1620626011761-996317b8d101?auto=format&fit=crop&q=80&w=800"
            width="800"
            height="534"
            loading="lazy"
            decoding="async"
            alt="Luxury bathroom renovation in Hampstead"
            class="rounded-lg shadow-lg"
          />
          <p class="mt-4 text-sm text-gray-500 italic">Award-winning bathroom featuring Italian marble and smart wellness technology</p>
        </div>
      </div>
    </div>
  </section>

  <!-- House Extensions Section -->
  <section id="house-extensions" class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
        <div class="order-2 lg:order-1">
          <img 
            src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&q=80&w=800"
            width="800"
            height="534"
            loading="lazy"
            decoding="async"
            alt="Contemporary house extension in Richmond"
            class="rounded-lg shadow-lg"
          />
          <p class="mt-4 text-sm text-gray-500 italic">Glass extension project in Richmond, seamlessly blending contemporary design with period architecture</p>
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-brand-green font-semibold">Architectural Extensions</span>
          <h2 class="text-3xl font-bold text-gray-900 mt-2 mb-6">Expanding Possibilities Through Architectural Innovation</h2>
          <p class="text-lg text-gray-600 mb-8">
            With over 75 successful extensions completed across Southwest London, we've mastered the art of seamlessly integrating new spaces with existing architecture. Our recent Chelsea project added 40% more living space while increasing the property's value by £750,000.
          </p>
          <div class="bg-white p-6 rounded-lg shadow-sm mb-8">
            <h3 class="text-xl font-bold text-gray-900 mb-4">The Extension Journey</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">End-to-End Management</span>
                  <p class="text-gray-600 mt-1">From planning permission to final decoration, we handle everything</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Architectural Excellence</span>
                  <p class="text-gray-600 mt-1">Award-winning architects and structural engineers ensure perfect execution</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Minimal Disruption</span>
                  <p class="text-gray-600 mt-1">Innovative construction methods minimize impact on your daily life</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <span class="font-semibold">Future-Proof Design</span>
                  <p class="text-gray-600 mt-1">Sustainable materials and energy-efficient solutions as standard</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="mt-8">
            <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-green hover:bg-brand-green/90">
              Explore Extension Options
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-brand-green rounded-lg shadow-xl overflow-hidden">
        <div class="px-6 py-12 md:p-12 text-center">
          <h2 class="text-3xl font-extrabold text-white mb-4">
            Ready to Transform Your Home?
          </h2>
          <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
            Join the growing number of Southwest London homeowners who've trusted us to create their dream spaces. Book a consultation today and discover the possibilities for your home.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="inline-flex items-center justify-center px-8 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-brand-green bg-white hover:bg-gray-50 transition-colors duration-200">
              Book a Consultation
            </a>
            <a href="/portfolio" class="inline-flex items-center justify-center px-8 py-3 border border-white rounded-md shadow-sm text-base font-medium text-white hover:bg-white/10 transition-colors duration-200">
              View Our Portfolio
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>