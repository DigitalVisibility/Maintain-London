---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

// Hard-code some project information for now
const projects = [
  { 
    name: 'holland-park', 
    title: 'Holland Park', 
    description: 'Apartment redesign and renovation',
    image: '/images/portfolio/projects/holland-park/10.-Holland-Park-Apartment-Redesign.-Decorbuddi-48.webp'
  },
  { 
    name: 'raymond-rd', 
    title: 'Raymond Road', 
    description: 'Complete home renovation',
    image: '/images/portfolio/projects/raymond-rd/62-Raymond-Rd-34.webp'
  },
  { 
    name: 'seagrave-road', 
    title: 'Seagrave Road', 
    description: 'Luxury renovation project',
    image: '/images/portfolio/projects/seagrave-road/82936_167-Seagrave-Road28_26 (10)_low.webp'
  },
  { 
    name: 'charlotte-street', 
    title: 'Charlotte Street', 
    description: 'Apartment renovation',
    image: '/images/portfolio/projects/charlotte-street/Charlotte street 1.webp'
  },
  { 
    name: 'chesterton-road', 
    title: 'Chesterton Road', 
    description: 'Home transformation',
    image: '/images/portfolio/projects/chesterton-road/Chesterton Road web-01.webp'
  },
  { 
    name: 'wimbledon', 
    title: 'Wimbledon', 
    description: 'Upscale home renovation',
    image: '/images/portfolio/projects/wimbledon/Wimbledon_Living_Room_1.webp'
  }
];

// Hard-code some sample images for categories
const kitchenImages = [
  '/images/portfolio/kitchens/10.-Holland-Park-Apartment-Redesign.-Decorbuddi-48.webp',
  '/images/Modern-Kitchen-Renovation-by-Maintain-London.webp',
  '/images/portfolio/kitchens/Chesterton Road web-01.webp'
];

const bathroomImages = [
  '/images/portfolio/bathrooms/Decorbuddi_Guest_Bathroom_Charlotte_Street_Apartment_13.webp',
  '/images/portfolio/bathrooms/Decorbuddi_Master_En_suite_Charlotte_Street_Apartment_5.webp',
  '/images/portfolio/bathrooms/Decorbuddi_Master_En_suite_Charlotte_Street_Apartment_6.webp'
];
---

<Layout title="Our Portfolio - Maintain London | Premium Home Renovations">
  <Navigation />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Our Signature Projects
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          Discover how we've transformed some of Southwest London's most distinguished properties, creating spaces that inspire and delight.
        </p>
      </div>
    </div>
  </section>

  <!-- Project Categories -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap justify-center gap-4 mb-16">
        <button data-category="all" class="category-filter px-6 py-2 rounded-full bg-brand-green text-white hover:bg-brand-green/90 transition-colors duration-200">
          All Projects
        </button>
        <button data-category="renovation" class="category-filter px-6 py-2 rounded-full bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors duration-200">
          Full Renovations
        </button>
        <button data-category="kitchen" class="category-filter px-6 py-2 rounded-full bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors duration-200">
          Kitchen Design
        </button>
        <button data-category="bathroom" class="category-filter px-6 py-2 rounded-full bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors duration-200">
          Bathroom Design
        </button>
        <button data-category="extension" class="category-filter px-6 py-2 rounded-full bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors duration-200">
          Extensions
        </button>
      </div>

      <!-- Featured Project -->
      <div class="mb-24">
        <div class="relative h-[600px] rounded-lg overflow-hidden">
          <img
            src={projects[0].image}
            alt={`${projects[0].title} by Maintain London`}
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent">
            <div class="absolute bottom-0 left-0 right-0 p-8 text-white">
              <span class="text-brand-green font-semibold">Featured Project</span>
              <h2 class="text-3xl font-bold mt-2 mb-4">{projects[0].title} Project</h2>
              <p class="text-lg text-gray-200 mb-6 max-w-2xl">
                {projects[0].description}
              </p>
              <a href={`/portfolio/${projects[0].name}`} class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200">
                View Project Details
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Project Grid -->
      <div id="project-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <div class="group relative project-item" data-category="renovation">
            <div class="relative h-[400px] rounded-lg overflow-hidden">
              <img
                src={project.image}
                alt={`${project.title} by Maintain London`}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <div class="absolute bottom-0 left-0 right-0 p-6">
                  <span class="text-brand-green font-semibold">Renovation Project</span>
                  <h3 class="text-xl font-bold text-white mt-2 mb-2">{project.title}</h3>
                  <p class="text-gray-200 mb-4">{project.description}</p>
                  <a href={`/portfolio/${project.name}`} class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200">
                    View Project
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}

        {kitchenImages.map((image, index) => (
          <div class="group relative project-item" data-category="kitchen">
            <div class="relative h-[400px] rounded-lg overflow-hidden">
              <img
                src={image}
                alt={`Kitchen design project by Maintain London`}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <div class="absolute bottom-0 left-0 right-0 p-6">
                  <span class="text-brand-green font-semibold">Kitchen Design</span>
                  <h3 class="text-xl font-bold text-white mt-2 mb-2">Modern Kitchen {index + 1}</h3>
                  <p class="text-gray-200 mb-4">Elegant kitchen design with premium finishes</p>
                  <a href="/portfolio/kitchens" class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200">
                    View Project
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}

        {bathroomImages.map((image, index) => (
          <div class="group relative project-item" data-category="bathroom">
            <div class="relative h-[400px] rounded-lg overflow-hidden">
              <img
                src={image}
                alt={`Bathroom design project by Maintain London`}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <div class="absolute bottom-0 left-0 right-0 p-6">
                  <span class="text-brand-green font-semibold">Bathroom Design</span>
                  <h3 class="text-xl font-bold text-white mt-2 mb-2">Luxury Bathroom {index + 1}</h3>
                  <p class="text-gray-200 mb-4">Spa-inspired bathroom with premium fixtures</p>
                  <a href="/portfolio/bathrooms" class="inline-flex items-center text-white hover:text-brand-green transition-colors duration-200">
                    View Project
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Load More Button -->
      <div class="text-center mt-16">
        <button id="load-more" class="inline-flex items-center justify-center px-8 py-3 border border-gray-300 rounded-md shadow-sm text-base font-medium text-gray-700 bg-white hover:bg-gray-50 transition-colors duration-200">
          Load More Projects
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  // Category filtering
  document.addEventListener('DOMContentLoaded', () => {
    const categoryButtons = document.querySelectorAll('.category-filter');
    const projectItems = document.querySelectorAll('.project-item');

    categoryButtons.forEach(button => {
      button.addEventListener('click', () => {
        // Remove active class from all buttons
        categoryButtons.forEach(btn => {
          btn.classList.remove('bg-brand-green', 'text-white');
          btn.classList.add('bg-gray-100', 'text-gray-700');
        });

        // Add active class to clicked button
        button.classList.remove('bg-gray-100', 'text-gray-700');
        button.classList.add('bg-brand-green', 'text-white');

        const category = button.getAttribute('data-category');

        // Show/hide projects based on category
        projectItems.forEach(item => {
          if (category === 'all' || item.getAttribute('data-category') === category) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });

    // Load more functionality
    const loadMoreButton = document.getElementById('load-more');
    if (loadMoreButton) {
      loadMoreButton.addEventListener('click', () => {
        const hiddenProjects = document.querySelectorAll('.project-item[style="display: none;"]');
        const projectsToShow = Array.from(hiddenProjects).slice(0, 3);

        projectsToShow.forEach(project => {
          project.style.display = 'block';
        });

        if (hiddenProjects.length <= 3) {
          loadMoreButton.style.display = 'none';
        }
      });
    }
  });
</script>
