---
export const prerender = false;

import HubLayout from '../../../../layouts/HubLayout.astro';
import ReportPreview from '../../../../components/project-hub/ReportPreview';
import { queryAll, queryOne } from '../../../../lib/db';
import type { Project, DiaryEntry } from '../../../../types/diary';

const { env } = Astro.locals.runtime;
const { id } = Astro.params;

const project = await queryOne<Project>(env.DB, 'SELECT * FROM projects WHERE id = ?', [id]);
if (!project) return Astro.redirect('/project-hub/');

const entries = await queryAll<DiaryEntry>(
  env.DB,
  'SELECT id, date, status FROM diary_entries WHERE project_id = ? ORDER BY date DESC',
  [id]
);
---

<HubLayout title={`Reports — ${project.name}`}>
  <div class="max-w-4xl mx-auto">
    <!-- Back link -->
    <a href={`/project-hub/project/${id}/`} class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-4 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
      </svg>
      {project.name}
    </a>

    <h1 class="text-2xl font-bold text-gray-900 font-display mb-6">Reports</h1>

    <ReportPreview
      client:load
      projectId={id!}
      entries={entries.map((e) => ({ id: e.id, date: e.date, status: e.status }))}
    />
  </div>
</HubLayout>
