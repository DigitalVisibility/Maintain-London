---
export const prerender = false;

import HubLayout from '../../layouts/HubLayout.astro';

const user = Astro.locals.user;
---

<HubLayout title="Settings">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold text-gray-900 font-display mb-6">Settings</h1>

    <!-- Profile -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5 mb-6">
      <h2 class="text-sm font-semibold text-gray-900 mb-4">Profile</h2>
      <div class="space-y-3">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-full bg-[#AEDE4A]/20 flex items-center justify-center text-[#6B8F2E] text-xl font-bold">
            {user?.name?.charAt(0)?.toUpperCase() || 'U'}
          </div>
          <div>
            <div class="text-base font-semibold text-gray-900">{user?.name || 'User'}</div>
            <div class="text-sm text-gray-500">{user?.email || ''}</div>
            <div class="text-xs text-gray-400 capitalize mt-0.5">{user?.role || 'operative'}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- App Info -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5 mb-6">
      <h2 class="text-sm font-semibold text-gray-900 mb-4">App Information</h2>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Version</dt>
          <dd class="text-gray-900 font-medium">1.0.0 MVP</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Platform</dt>
          <dd class="text-gray-900 font-medium">Cloudflare Workers + D1 + R2</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">PWA Status</dt>
          <dd class="text-gray-900 font-medium" id="pwa-status">Checking...</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Service Worker</dt>
          <dd class="text-gray-900 font-medium" id="sw-status">Checking...</dd>
        </div>
      </dl>
    </div>

    <!-- PWA Install -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5 mb-6" id="install-section" style="display:none">
      <h2 class="text-sm font-semibold text-gray-900 mb-2">Install App</h2>
      <p class="text-sm text-gray-500 mb-4">
        Install Project Hub on your device for quick access and offline support.
      </p>
      <button
        type="button"
        id="install-btn"
        class="inline-flex items-center gap-2 px-4 py-2.5 bg-[#AEDE4A] hover:bg-[#9BCF3A] text-gray-900 font-semibold rounded-md text-sm transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fillRule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clipRule="evenodd" />
        </svg>
        Install Project Hub
      </button>
    </div>

    <!-- Danger Zone -->
    <div class="bg-white rounded-lg shadow-sm border border-red-200 p-5">
      <h2 class="text-sm font-semibold text-red-600 mb-4">Account</h2>
      <form method="POST" action="/api/auth/sign-out">
        <button
          type="submit"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-md transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fillRule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clipRule="evenodd" />
          </svg>
          Sign Out
        </button>
      </form>
    </div>
  </div>
</HubLayout>

<script is:inline>
  // Check PWA install state
  const pwaStatus = document.getElementById('pwa-status');
  const swStatus = document.getElementById('sw-status');
  const installSection = document.getElementById('install-section');
  const installBtn = document.getElementById('install-btn');

  if (window.matchMedia('(display-mode: standalone)').matches) {
    pwaStatus.textContent = 'Installed (Standalone)';
  } else {
    pwaStatus.textContent = 'Not installed (Browser)';
  }

  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.getRegistration('/project-hub/').then((reg) => {
      swStatus.textContent = reg ? 'Active' : 'Not registered';
    });
  } else {
    swStatus.textContent = 'Not supported';
  }

  // PWA install prompt
  let deferredPrompt = null;
  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;
    installSection.style.display = 'block';
  });

  installBtn.addEventListener('click', async () => {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    const result = await deferredPrompt.userChoice;
    if (result.outcome === 'accepted') {
      installSection.style.display = 'none';
      pwaStatus.textContent = 'Installed (Standalone)';
    }
    deferredPrompt = null;
  });
</script>
