---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Apps - Maintain London | Smart Solutions for Home Renovation">
  <Navigation />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Smart Solutions Coming Soon
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          We're developing innovative applications powered by AI to revolutionize your renovation experience.
        </p>
      </div>
    </div>
  </section>

  <!-- Upcoming Apps -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Pricing Calculator -->
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Smart Pricing Calculator</h2>
          <p class="text-gray-600 mb-6">
            Our AI-powered pricing calculator will provide instant, accurate estimates for your renovation projects. By analyzing thousands of past projects and current market data, it delivers precise quotes tailored to your specific requirements.
          </p>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start">
              <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-600">Real-time cost estimation</span>
            </li>
            <li class="flex items-start">
              <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-600">Material cost optimization</span>
            </li>
            <li class="flex items-start">
              <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-600">Market-adjusted pricing</span>
            </li>
          </ul>
          <p class="text-sm text-gray-500">Coming Q3 2025</p>
        </div>

        <!-- Project Management Portal -->
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Client Management Portal</h2>
          <p class="text-gray-600 mb-6">
            A comprehensive platform that gives you complete visibility and control over your renovation project. Track progress, communicate with our team, and manage documents all in one place.
          </p>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start">
              <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-600">Real-time project updates</span>
            </li>
            <li class="flex items-start">
              <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-600">Document management</span>
            </li>
            <li class="flex items-start">
              <svg class="h-6 w-6 text-brand-green mt-1 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-gray-600">Direct team communication</span>
            </li>
          </ul>
          <p class="text-sm text-gray-500">Coming Q4 2025</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Integration -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900">AI-Powered Innovation</h2>
        <p class="mt-4 text-xl text-gray-600">
          We're leveraging cutting-edge AI technology to enhance every aspect of your renovation journey.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Predictive Analytics</h3>
          <p class="text-gray-600">
            Our AI analyzes market trends and historical data to optimize project timelines and resource allocation, ensuring efficient delivery.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Smart Recommendations</h3>
          <p class="text-gray-600">
            Get personalized material and design suggestions based on your style preferences and budget constraints.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Quality Assurance</h3>
          <p class="text-gray-600">
            AI-powered quality control systems monitor project progress and ensure adherence to our high standards.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-brand-green rounded-lg shadow-xl overflow-hidden">
        <div class="px-6 py-12 md:p-12 text-center">
          <h2 class="text-3xl font-extrabold text-white mb-4">
            Stay Updated
          </h2>
          <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
            Be the first to know when our smart solutions launch. Sign up for early access and exclusive updates.
          </p>
          <form class="max-w-md mx-auto">
            <div class="flex gap-4">
              <input
                type="email"
                placeholder="Enter your email"
                class="flex-1 rounded-md border-0 px-4 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-white"
              />
              <button
                type="submit"
                class="rounded-md bg-white px-6 py-3 text-base font-semibold text-brand-green shadow-sm hover:bg-gray-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
              >
                Subscribe
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>