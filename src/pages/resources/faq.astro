---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What areas do you cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We primarily serve Southwest London and Surrey, focusing on properties valued at £1m+. Our core service areas include Richmond, Chelsea, Hampstead, Walton-on-Thames, and surrounding neighbourhoods."
      }
    },
    {
      "@type": "Question",
      "name": "Are you fully insured?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, we carry comprehensive insurance coverage including public liability insurance up to £5 million and professional indemnity insurance up to £2 million."
      }
    },
    {
      "@type": "Question",
      "name": "How long has Maintain London been operating?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Established in 2015, we've completed over 500 high-end renovation projects across London, building a reputation for excellence in luxury home renovations."
      }
    },
    {
      "@type": "Question",
      "name": "What types of projects do you handle?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We specialize in high-end home renovations, kitchen and bathroom designs, house extensions, and complete property refurbishments for premium properties."
      }
    },
    {
      "@type": "Question",
      "name": "How long does a typical renovation take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kitchen renovations: 4-6 weeks. Bathroom renovations: 2-3 weeks. Full home renovations: 3-6 months. Extensions: 3-4 months."
      }
    },
    {
      "@type": "Question",
      "name": "What is your project management approach?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Each project is assigned a dedicated project manager who oversees all aspects from planning to completion. You'll receive regular updates and have 24/7 access to our project management platform."
      }
    },
    {
      "@type": "Question",
      "name": "Do you handle all necessary permits?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, we manage all aspects of planning permission, building regulations approval, and any other required permits as part of our comprehensive service."
      }
    },
    {
      "@type": "Question",
      "name": "What is your pricing structure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We provide detailed, transparent quotes. Typical investment ranges: Kitchen renovations £50,000-£150,000. Bathroom renovations £25,000-£75,000. Extensions £100,000-£500,000+."
      }
    },
    {
      "@type": "Question",
      "name": "What are your payment terms?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "10% deposit upon contract signing, 30% at project commencement, remaining balance paid in agreed stages based on progress."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer any guarantees?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, all our work comes with a 10-year structural warranty, 2-year craftsmanship guarantee, and manufacturer warranties on all fixtures and appliances."
      }
    },
    {
      "@type": "Question",
      "name": "What materials do you use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We source premium materials including Italian marble and stone, German-engineered appliances, sustainable hardwoods, and premium British and European fixtures."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer smart home integration?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, we can incorporate various smart home systems including lighting, heating, security, and home automation. We work with leading brands and certified installers."
      }
    }
  ]
});
---

<Layout
  title="FAQ - Maintain London | Home Renovation Questions Answered"
  description="Get answers to common questions about Maintain London's premium home renovation services, pricing, timelines, and process. Serving Southwest London and Surrey since 2015."
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Resources", url: "/resources/faq" },
    { name: "FAQ", url: "/resources/faq" }
  ]}
  schema={faqSchema}
>
  <Navigation />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
          Frequently Asked Questions
        </h1>
        <p class="mt-6 max-w-3xl mx-auto text-xl text-gray-500">
          Everything you need to know about our renovation services, process, and commitment to quality.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Categories -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
        <!-- General Questions -->
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">General Questions</h3>
          <p class="text-gray-600">Basic information about our services and company</p>
        </div>

        <!-- Process -->
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Our Process</h3>
          <p class="text-gray-600">Understanding how we work and what to expect</p>
        </div>

        <!-- Pricing -->
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Pricing & Payment</h3>
          <p class="text-gray-600">Information about costs, payment terms, and financing</p>
        </div>

        <!-- Technical -->
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-brand-green/10 rounded-lg flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Technical Details</h3>
          <p class="text-gray-600">Specifications, materials, and technical processes</p>
        </div>
      </div>

      <!-- FAQ Sections -->
      <div class="space-y-16">
        <!-- General Questions -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-8">General Questions</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">What areas do you cover?</h3>
              <p class="text-gray-600">
                We primarily serve Southwest London and Surrey, focusing on properties valued at £1m+. Our core service areas include Richmond, Chelsea, Hampstead, and surrounding neighborhoods.
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">Are you fully insured?</h3>
              <p class="text-gray-600">
                Yes, we carry comprehensive insurance coverage including public liability insurance up to £5 million and professional indemnity insurance up to £2 million.
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">How long has Maintain London been operating?</h3>
              <p class="text-gray-600">
                Established in 2015, we've completed over 500 high-end renovation projects across London, building a reputation for excellence in luxury home renovations.
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">What types of projects do you handle?</h3>
              <p class="text-gray-600">
                We specialize in high-end home renovations, kitchen and bathroom designs, house extensions, and complete property refurbishments for premium properties.
              </p>
            </div>
          </div>
        </div>

        <!-- Process Questions -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-8">Our Process</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">How long does a typical renovation take?</h3>
              <p class="text-gray-600">
                Project timelines vary based on scope:
                <br>• Kitchen renovations: 4-6 weeks
                <br>• Bathroom renovations: 2-3 weeks
                <br>• Full home renovations: 3-6 months
                <br>• Extensions: 3-4 months
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">What is your project management approach?</h3>
              <p class="text-gray-600">
                Each project is assigned a dedicated project manager who oversees all aspects from planning to completion. You'll receive regular updates and have 24/7 access to our project management platform.
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">Do you handle all necessary permits?</h3>
              <p class="text-gray-600">
                Yes, we manage all aspects of planning permission, building regulations approval, and any other required permits as part of our comprehensive service.
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">How do you minimize disruption during renovations?</h3>
              <p class="text-gray-600">
                We employ dust containment systems, maintain strict working hours, and coordinate deliveries to minimize impact. For occupied properties, we can phase work to maintain livable conditions.
              </p>
            </div>
          </div>
        </div>

        <!-- Pricing Questions -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-8">Pricing & Payment</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">What is your pricing structure?</h3>
              <p class="text-gray-600">
                We provide detailed, transparent quotes based on your specific requirements. Typical investment ranges:
                <br>• Kitchen renovations: £50,000-£150,000
                <br>• Bathroom renovations: £25,000-£75,000
                <br>• Extensions: £100,000-£500,000+
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">What are your payment terms?</h3>
              <p class="text-gray-600">
                We typically structure payments in stages:
                <br>• 10% deposit upon contract signing
                <br>• 30% at project commencement
                <br>• Remaining balance paid in agreed stages based on progress
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">Do you offer any guarantees?</h3>
              <p class="text-gray-600">
                Yes, all our work comes with:
                <br>• 10-year structural warranty
                <br>• 2-year craftsmanship guarantee
                <br>• Manufacturer warranties on all fixtures and appliances
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">Do you offer financing options?</h3>
              <p class="text-gray-600">
                While we don't provide direct financing, we can recommend trusted financial partners who specialize in renovation loans and have experience with high-value property improvements.
              </p>
            </div>
          </div>
        </div>

        <!-- Technical Questions -->
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-8">Technical Details</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">What materials do you use?</h3>
              <p class="text-gray-600">
                We source premium materials from trusted suppliers, including:
                <br>• Italian marble and stone
                <br>• German-engineered appliances
                <br>• Sustainable hardwoods
                <br>• Premium British and European fixtures
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">How do you handle period properties?</h3>
              <p class="text-gray-600">
                Our team has extensive experience with period properties. We use specialized techniques and materials to preserve original features while incorporating modern amenities and meeting current building regulations.
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">Do you offer smart home integration?</h3>
              <p class="text-gray-600">
                Yes, we can incorporate various smart home systems including lighting, heating, security, and home automation. We work with leading brands and certified installers.
              </p>
            </div>

            <div class="bg-white p-6 rounded-lg shadow-sm">
              <h3 class="text-lg font-bold text-gray-900 mb-4">What about sustainability?</h3>
              <p class="text-gray-600">
                We prioritize sustainable practices including:
                <br>• Energy-efficient systems
                <br>• Sustainable material sourcing
                <br>• Waste reduction and recycling
                <br>• Water-saving fixtures
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Still Have Questions -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-lg shadow-xl overflow-hidden">
        <div class="lg:grid lg:grid-cols-2">
          <div class="relative">
            <img
              src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80"
              alt="Maintain London team discussing renovation plans"
              class="h-full w-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-black/60 to-transparent">
              <div class="p-12">
                <h3 class="text-3xl font-bold text-white mb-4">Still Have Questions?</h3>
                <p class="text-lg text-white/90">
                  Our team is here to help you understand every aspect of your renovation journey.
                </p>
              </div>
            </div>
          </div>
          <div class="p-12">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">Get in Touch</h3>
            <div class="space-y-6">
              <div class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <div>
                  <h4 class="font-semibold text-gray-900">Call Us</h4>
                  <p class="text-gray-600"><a href="tel:+442038862023" class="hover:text-brand-green transition-colors">020 3886 2023</a></p>
                </div>
              </div>
              <div class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <div>
                  <h4 class="font-semibold text-gray-900">Email Us</h4>
                  <p class="text-gray-600"><a href="mailto:team@maintainlondon.co.uk" class="hover:text-brand-green transition-colors">team@maintainlondon.co.uk</a></p>
                </div>
              </div>
              <div class="flex items-start">
                <svg class="h-6 w-6 text-brand-green mt-1 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <div>
                  <h4 class="font-semibold text-gray-900">Visit Us</h4>
                  <p class="text-gray-600">
                    5 Garden Road<br/>
                    Walton-on-Thames<br/>
                    KT12 2HQ
                  </p>
                </div>
              </div>
            </div>
            <div class="mt-8">
              <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-green hover:bg-brand-green/90">
                Contact Us
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>