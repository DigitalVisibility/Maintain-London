---
import { projects, imageMetadata } from '../data/portfolio-metadata.js';

// Select 3 top featured projects
const featuredProjects = [
  {
    ...projects.find(p => p.id === 'holland-park'),
    // Add high-quality images for this project
    images: imageMetadata.filter(img => img.project === 'holland-park').slice(0, 2),
    category: 'Luxury Apartment Redesign'
  },
  {
    ...projects.find(p => p.id === 'chesterton-road'),
    // Add high-quality images for this project
    images: imageMetadata.filter(img => img.project === 'chesterton-road').slice(0, 2),
    category: 'Full Home Transformation'
  },
  {
    ...projects.find(p => p.id === 'charlotte-street'),
    // Add high-quality images for this project
    images: imageMetadata.filter(img => img.project === 'charlotte-street').slice(0, 2),
    category: 'Modern Interior Design'
  }
];
---

<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 max-w-3xl mx-auto">
      <span class="text-brand-green font-semibold tracking-wider uppercase text-sm">Our Portfolio</span>
      <h2 class="mt-2 text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight">
        Exceptional Projects<br class="hidden sm:inline"> <span class="text-brand-green">Across London</span>
      </h2>
      <p class="mt-5 text-xl text-gray-600 max-w-2xl mx-auto">
        From luxury apartments to complete home transformations, discover our finest work
      </p>
    </div>
    
    <!-- Featured Projects with Showcase Design -->
    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-10 mb-16">
      {featuredProjects.map((project, index) => (
        <div data-aos="fade-up" data-aos-delay={index * 100} class="group bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-500 transform hover:-translate-y-1">
          <!-- Main Featured Image with Caption -->
          <div class="relative overflow-hidden aspect-[4/3]">
            <img 
              src={project.featuredImage} 
              alt={project.name}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent opacity-70 group-hover:opacity-90 transition-opacity"></div>
            
            <!-- Project Category Badge -->
            <div class="absolute top-4 left-4">
              <span class="bg-brand-green/90 text-white text-xs uppercase tracking-wider px-3 py-1.5 rounded-full">
                {project.category}
              </span>
            </div>
            
            <!-- Project Title -->
            <div class="absolute bottom-0 left-0 right-0 p-6 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
              <h3 class="text-2xl font-bold text-white group-hover:text-brand-green transition-colors">{project.name}</h3>
              <p class="text-white/80 text-sm mt-2 max-w-xs opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                {project.description}
              </p>
            </div>
          </div>
          
          <!-- Thumbnail Preview Row -->
          <div class="p-4 bg-white flex gap-2 border-t border-gray-100">
            {project.images.map((image) => (
              <div class="flex-1 aspect-[4/3] overflow-hidden rounded-md">
                <img 
                  src={image.src} 
                  alt={image.alt}
                  class="w-full h-full object-cover hover:scale-110 transition-transform duration-300"
                  loading="lazy"
                />
              </div>
            ))}
            
            <!-- CTA Link -->
            <div class="flex-1 flex items-center justify-center bg-gray-50 rounded-md">
              <a 
                href={`/portfolio?project=${project.id}`}
                class="flex items-center justify-center w-full h-full text-brand-green font-medium hover:bg-brand-green/10 transition-colors rounded-md group"
                aria-label={`View ${project.name} project details`}
              >
                <span class="mr-2 text-sm">View</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
    

    
    <!-- CTA Section -->
    <div class="text-center">
      <a 
        href="/portfolio" 
        class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-base font-medium rounded-lg text-white bg-brand-green shadow-lg hover:bg-brand-green/90 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-xl"
      >
        Explore All Our Projects
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 animate-pulse" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
      <p class="mt-4 text-gray-500 text-sm">Discover our complete range of renovation and design services</p>
    </div>
  </div>
</section>
