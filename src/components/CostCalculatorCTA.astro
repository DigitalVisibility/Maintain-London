---
// Cost Calculator CTA Component for Home Page
---

<section class="py-16 bg-gradient-to-r from-brand-green to-green-600">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <!-- Hook -->
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Curious About Your Project Cost?
      </h2>
      <p class="text-xl text-white/90 mb-8 max-w-3xl mx-auto">
        Get an instant estimate for your London home renovation, extension, or loft conversion in just 30 seconds. Our smart calculator uses real London market rates.
      </p>
      
      <!-- Benefits Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="flex flex-col items-center text-white">
          <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">30-Second Estimate</h3>
          <p class="text-sm text-white/80">Quick, accurate pricing</p>
        </div>
        
        <div class="flex flex-col items-center text-white">
          <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">London-Specific</h3>
          <p class="text-sm text-white/80">Real market rates by area</p>
        </div>
        
        <div class="flex flex-col items-center text-white">
          <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-semibold mb-2">100% Free</h3>
          <p class="text-sm text-white/80">No email required</p>
        </div>
      </div>
      
      <!-- CTA Button -->
      <div class="flex justify-center">
        <a href="/resources/cost-calculator" class="inline-flex items-center px-8 py-4 bg-white text-brand-green font-semibold rounded-lg shadow-lg hover:bg-gray-50 transition-all duration-200 transform hover:scale-105 text-lg">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
          Calculate Your Build Cost
        </a>
      </div>
      
      <!-- Trust Signal -->
      <p class="text-white/70 text-sm mt-6">
        ✓ Used by 1,000+ London homeowners  ✓ Based on real project data  ✓ Instant results
      </p>
    </div>
  </div>
</section> 