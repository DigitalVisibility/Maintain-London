---
---

<section class="relative bg-white pt-32 pb-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-12 lg:gap-8">
      <div class="sm:text-center md:max-w-2xl md:mx-auto lg:col-span-6 lg:text-left">
        <h1>
          <span class="block text-base text-brand-green font-semibold tracking-wide uppercase">Transform Your Space</span>
          <span class="mt-1 block text-4xl tracking-tight font-extrabold sm:text-5xl xl:text-6xl">
            High-End Home Renovations in London
          </span>
        </h1>
        <p class="mt-3 text-base text-gray-500 sm:mt-5 sm:text-xl lg:text-lg xl:text-xl">
          From complete home renovations to stunning kitchen and bathroom designs, we bring your vision to life with exceptional craftsmanship and attention to detail.
        </p>
        <div class="mt-8 sm:max-w-lg sm:mx-auto sm:text-center lg:text-left lg:mx-0">
          <div class="flex flex-col sm:flex-row gap-4 sm:justify-center lg:justify-start">
            <a href="/quote" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-brand-green hover:bg-brand-green/90 transition-colors duration-200">
              Get a Free Quote
            </a>
            <a href="/portfolio" class="inline-flex items-center justify-center px-8 py-3 border border-gray-300 text-base font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors duration-200">
              View Our Work
            </a>
          </div>
        </div>
        <div class="mt-6 sm:mt-8">
          <dl class="grid grid-cols-2 gap-x-4 gap-y-8">
            <div class="border-l-2 border-brand-green pl-4">
              <dt class="text-sm font-medium text-gray-500">Service Area</dt>
              <dd class="mt-1 text-2xl font-extrabold text-gray-900">SW London</dd>
            </div>
            <div class="border-l-2 border-brand-green pl-4">
              <dt class="text-sm font-medium text-gray-500">Experience</dt>
              <dd class="mt-1 text-2xl font-extrabold text-gray-900">15+ Years</dd>
            </div>
          </dl>
        </div>
      </div>
      <div class="mt-12 relative sm:max-w-lg sm:mx-auto lg:mt-0 lg:max-w-none lg:mx-0 lg:col-span-6 lg:flex lg:items-center">
        <div class="relative mx-auto w-full rounded-lg shadow-lg lg:max-w-md">
          <img
            class="w-full rounded-lg"
            src="/images/Modern-Kitchen-Renovation-by-Maintain-London.webp"
            alt="Contemporary open-plan kitchen featuring a two-tone design with white upper cabinets and dark grey lower cabinets. Large central island with concrete-look countertop, natural lighting from skylights and bi-fold doors leading to a garden. Wooden dining set and orchid plants add warmth to the minimalist space."
          />
        </div>
      </div>
    </div>
  </div>
</section>