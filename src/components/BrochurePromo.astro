---
// Simple component to promote the digital brochure that can be included on multiple pages
---

<div class="bg-gray-50 rounded-xl p-6 shadow-sm border border-gray-100">
  <div class="flex flex-col md:flex-row items-center gap-6">
    <div class="w-full md:w-1/3">
      <div class="relative">
        <img 
          src="/images/brochure-cover.webp" 
          alt="Maintain London Digital Brochure" 
          class="w-full h-auto shadow-lg rounded-md transform -rotate-3 hover:rotate-0 transition-transform duration-300"
          onerror="this.src='/Digital Brochure.pdf'; this.onerror=null;"
        />
        <div class="absolute top-0 right-0 -mr-2 -mt-2 bg-brand-green text-white text-xs font-bold px-2 py-1 rounded-full">
          NEW
        </div>
      </div>
    </div>
    
    <div class="w-full md:w-2/3 text-center md:text-left">
      <h3 class="text-xl font-bold text-gray-900 mb-2">Our Digital Portfolio Brochure</h3>
      <p class="text-gray-600 mb-4">
        Explore our complete showcase of premium renovation projects and design services in our interactive digital brochure.
      </p>
      
      <div class="flex flex-wrap gap-3 justify-center md:justify-start">
        <a 
          href="/brochure" 
          class="inline-flex items-center px-4 py-2 bg-brand-green text-white rounded-md hover:bg-brand-green/90 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z" />
          </svg>
          View Interactive Brochure
        </a>
        
        <a 
          href="/Digital Brochure.pdf" 
          download
          class="inline-flex items-center px-4 py-2 border border-brand-green text-brand-green rounded-md hover:bg-gray-100 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
          Download PDF
        </a>
      </div>
    </div>
  </div>
</div>
