<style>
  .image-container {
    position: relative;
    width: 100%;
    height: 500px;
    overflow: hidden;
    border-radius: 0.5rem;
  }

  .image-container::before {
    content: '';
    position: absolute;
    inset: -5px;
    background: inherit;
    filter: blur(10px);
    z-index: -1;
  }

  .image-container::after {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.3) 0%,
        rgba(255, 255, 255, 0) 30%,
        rgba(255, 255, 255, 0) 70%,
        rgba(255, 255, 255, 0.3) 100%
      ),
      linear-gradient(
        to right,
        rgba(255, 255, 255, 0.3) 0%,
        rgba(255, 255, 255, 0) 30%,
        rgba(255, 255, 255, 0) 70%,
        rgba(255, 255, 255, 0.3) 100%
      );
    box-shadow: 
      inset 0 0 20px rgba(255, 255, 255, 0.5),
      inset 0 0 100px rgba(255, 255, 255, 0.2);
    pointer-events: none;
    border-radius: 0.5rem;
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0.5rem;
  }
</style>