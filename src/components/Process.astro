<section class="py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-extrabold text-gray-900 sm:text-5xl">
        Our Process
      </h2>
      <p class="mt-4 text-xl text-gray-500">
        Simple, transparent, and designed around you
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="text-center">
        <div class="w-16 h-16 bg-brand-green/10 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-3xl font-bold text-brand-green">1</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Initial Consultation</h3>
        <p class="text-gray-600">
          We meet to discuss your vision, requirements, and budget. Our experts provide initial guidance and ideas.
        </p>
      </div>

      <div class="text-center">
        <div class="w-16 h-16 bg-brand-green/10 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-3xl font-bold text-brand-green">2</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Design & Planning</h3>
        <p class="text-gray-600">
          Our designers create detailed plans and 3D visualizations. We handle all necessary permissions and approvals.
        </p>
      </div>

      <div class="text-center">
        <div class="w-16 h-16 bg-brand-green/10 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-3xl font-bold text-brand-green">3</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Construction</h3>
        <p class="text-gray-600">
          Our skilled team executes the project with precision, keeping you informed at every stage.
        </p>
      </div>

      <div class="text-center">
        <div class="w-16 h-16 bg-brand-green/10 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-3xl font-bold text-brand-green">4</span>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Completion</h3>
        <p class="text-gray-600">
          Final inspection ensures everything meets our high standards before handover.
        </p>
      </div>
    </div>
  </div>
</section>