---
import { projects, serviceCategories, imageMetadata, filterImages } from '../data/portfolio-metadata.js';

const { activeProject = 'all', activeCategory = 'all' } = Astro.props;
---

<section class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8">
      <h2 class="text-4xl font-extrabold text-gray-900 sm:text-5xl">
        Our Portfolio
      </h2>
      <p class="mt-4 text-xl text-gray-500">
        A showcase of our finest work across London
      </p>
    </div>
    
    <!-- Filtering Controls -->
    <div class="flex flex-col md:flex-row justify-center gap-6 mb-16">
      <div class="flex flex-col gap-2">
        <h3 class="text-lg font-semibold text-gray-800">Filter by Project</h3>
        <div class="flex flex-wrap gap-2">
          <a 
            href={`/portfolio?project=all&category=${activeCategory}`}
            data-project-filter="all"
            class={`px-4 py-2 rounded-full text-sm font-medium ${activeProject === 'all' ? 'bg-brand-green text-white' : 'bg-gray-200 text-gray-800 hover:bg-gray-300'}`}
          >
            All Projects
          </a>
          {projects.map(project => (
            <a 
              href={`/portfolio?project=${project.id}&category=${activeCategory}`}
              data-project-filter={project.id}
              class={`px-4 py-2 rounded-full text-sm font-medium ${activeProject === project.id ? 'bg-brand-green text-white' : 'bg-gray-200 text-gray-800 hover:bg-gray-300'}`}
            >
              {project.name}
            </a>
          ))}
        </div>
      </div>
      
      <div class="flex flex-col gap-2">
        <h3 class="text-lg font-semibold text-gray-800">Filter by Category</h3>
        <div class="flex flex-wrap gap-2">
          {serviceCategories.map(category => (
            <a 
              href={`/portfolio?project=${activeProject}&category=${category.id}`}
              data-category-filter={category.id}
              class={`px-4 py-2 rounded-full text-sm font-medium ${activeCategory === category.id ? 'bg-brand-green text-white' : 'bg-gray-200 text-gray-800 hover:bg-gray-300'}`}
            >
              {category.name}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Dynamic Gallery -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {imageMetadata.map(image => (
        <div 
          class="group relative overflow-hidden rounded-lg aspect-[4/3] portfolio-item"
          data-project={image.project}
          data-categories={JSON.stringify(image.categories)}
        >
          <img
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="text-xl font-bold text-white">{image.title}</h3>
              <p class="text-gray-200 mt-2">{image.description}</p>
              <div class="flex gap-2 mt-3">
                {image.categories.map(cat => {
                  const category = serviceCategories.find(c => c.id === cat);
                  return (
                    <span class="text-xs bg-white/20 text-white px-2 py-1 rounded-full">
                      {category ? category.name : cat}
                    </span>
                  );
                })}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- No Results Message -->
    <div id="no-results-message" class="text-center py-12" style="display: none;">
      <h3 class="text-xl font-medium text-gray-800">No projects found</h3>
      <p class="text-gray-600 mt-2">Try changing your filter selections</p>
      <a href="/portfolio" class="mt-4 inline-block text-brand-green hover:underline">View all projects</a>
    </div>

    {(activeProject !== 'all' || activeCategory !== 'all') && (
      <div class="text-center mt-12">
        <a
          href="/portfolio"
          class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-brand-green hover:bg-brand-green/90 transition-colors duration-200"
        >
          View All Projects
        </a>
      </div>
    )}
  </div>
</section>