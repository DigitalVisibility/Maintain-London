---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div>
        <div class="mb-6">
          <img
            src="/images/Icons/Stacked.png"
            alt="Maintain London - Premium Home Renovations"
            class="h-14 w-auto"
            width="120"
            height="56"
            loading="lazy"
          />
        </div>
        <p class="text-sm mb-4 speakable" data-speakable>
          Maintain London is Southwest London's trusted partner for high-end home renovations, luxury kitchens, bathrooms, extensions, and property development. Serving homes valued at £1m+ since 2015.
        </p>
        <div class="space-y-2 text-sm">
          <p class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>5 Garden Road<br/>Walton-on-Thames, KT12 2HQ</span>
          </p>
          <p class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+442038862023" class="hover:text-brand-green transition-colors duration-200">020 3886 2023</a>
          </p>
          <p class="flex items-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:team@maintainlondon.co.uk" class="hover:text-brand-green transition-colors duration-200">team@maintainlondon.co.uk</a>
          </p>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-semibold bg-clip-text text-transparent bg-gradient-green-pink mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-green-pink transition-all duration-200">About Us</a></li>
          <li><a href="/services" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-green-pink transition-all duration-200">Our Services</a></li>
          <li><a href="/portfolio" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-green-pink transition-all duration-200">Portfolio</a></li>
          <li><a href="/contact" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-green-pink transition-all duration-200">Contact</a></li>
          <li><a href="/resources/cost-calculator" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-green-pink transition-all duration-200">Cost Calculator</a></li>
          <li><a href="/contact" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-green-pink transition-all duration-200">Get a Free Quote</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-lg font-semibold bg-clip-text text-transparent bg-gradient-pink-purple mb-4">Our Services</h3>
        <ul class="space-y-2">
          <li><a href="/services/renovations" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-pink-purple transition-all duration-200">Home Renovation</a></li>
          <li><a href="/services/kitchens" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-pink-purple transition-all duration-200">Kitchen Design</a></li>
          <li><a href="/services/bathrooms" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-pink-purple transition-all duration-200">Bathroom Design</a></li>
          <li><a href="/services/extensions" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-pink-purple transition-all duration-200">House Extensions</a></li>
        </ul>
      </div>

      <!-- Business Hours -->
      <div>
        <h3 class="text-lg font-semibold bg-clip-text text-transparent bg-gradient-green-pink mb-4">Business Hours</h3>
        <ul class="space-y-2">
          <li class="flex justify-between">
            <span>Monday - Friday</span>
            <span>8:00 - 18:00</span>
          </li>
          <li class="flex justify-between">
            <span>Saturday</span>
            <span>9:00 - 14:00</span>
          </li>
          <li class="flex justify-between">
            <span>Sunday</span>
            <span>Closed</span>
          </li>
        </ul>

        <!-- Trust Signals -->
        <div class="mt-4 pt-4 border-t border-gray-700">
          <div class="flex items-center gap-2 text-sm text-gray-400 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            £5M Public Liability Insured
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-400 mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            10-Year Structural Warranty
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
