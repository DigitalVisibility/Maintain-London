              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-transparent bg-gradient-to-r from-brand-green/30 via-brand-pink/30 to-brand-purple/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="md:flex md:items-center md:justify-between">
        <div class="text-sm">
          <p>&copy; {currentYear} Maintain London. All rights reserved.</p>
          <p class="mt-2">Established 2015 &bull; 500+ Projects Completed</p>
        </div>
        <div class="mt-4 md:mt-0">
          <ul class="flex space-x-6 text-sm">
            <li><a href="/privacy-policy" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-tri-color transition-all duration-200">Privacy Policy</a></li>
            <li><a href="/terms" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-tri-color transition-all duration-200">Terms & Conditions</a></li>
            <li><a href="/sitemap-index.xml" class="hover:text-transparent hover:bg-clip-text hover:bg-gradient-tri-color transition-all duration-200">Sitemap</a></li>
          </ul>
        </div>
      </div>
