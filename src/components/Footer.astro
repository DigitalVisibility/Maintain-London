  <!-- Developer Credit -->
  <div class="border-t border-gray-800 bg-gray-900/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="text-center text-sm">
        <a
          href="https://digitalvisibility.com"
          target="_blank"
          rel="noopener noreferrer"
          title="Digital Visibility - Web Development & Digital Marketing Agency"
          class="inline-flex items-center text-gray-400 hover:text-brand-green transition-colors duration-200"
        >
          <span>Digital Visibility - Empowering businesses with strategic digital solutions</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
            <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
          </svg>
        </a>
      </div>
    </div>
  </div>

