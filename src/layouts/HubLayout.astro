---
import '@fontsource-variable/inter';
import '@fontsource/plus-jakarta-sans/latin-400.css';
import '@fontsource/plus-jakarta-sans/latin-600.css';
import '@fontsource/plus-jakarta-sans/latin-700.css';
import OfflineBanner from '../components/project-hub/OfflineBanner';

interface Props {
  title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | Project Hub | Maintain London</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#AEDE4A" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Project Hub" />
    <link rel="apple-touch-icon" href="/images/Icons/Stacked.png" />
  </head>
  <body class="bg-gray-50 font-sans">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar (desktop) -->
      <aside class="hidden md:flex md:w-64 md:flex-col bg-gray-900 text-white">
        <!-- Logo -->
        <div class="flex items-center gap-3 px-6 py-5 border-b border-gray-800">
          <img
            src="/images/Icons/Stacked.png"
            alt="Maintain London"
            class="h-10 w-auto"
          />
          <div>
            <div class="text-sm font-semibold">Project Hub</div>
            <div class="text-xs text-gray-400">Maintain London</div>
          </div>
        </div>

        <!-- Nav links -->
        <nav class="flex-1 px-4 py-4 space-y-1">
          <a
            href="/project-hub/"
            class:list={[
              'flex items-center gap-3 px-3 py-2 rounded-md text-sm transition-colors',
              currentPath === '/project-hub/' || currentPath === '/project-hub'
                ? 'bg-brand-green/20 text-brand-green'
                : 'text-gray-300 hover:bg-gray-800 hover:text-white',
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
            </svg>
            Dashboard
          </a>

          <a
            href="/project-hub/settings"
            class:list={[
              'flex items-center gap-3 px-3 py-2 rounded-md text-sm transition-colors',
              currentPath.startsWith('/project-hub/settings')
                ? 'bg-brand-green/20 text-brand-green'
                : 'text-gray-300 hover:bg-gray-800 hover:text-white',
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
            </svg>
            Settings
          </a>
        </nav>

        <!-- User section -->
        <div class="px-4 py-4 border-t border-gray-800">
          <div class="flex items-center gap-3 px-3">
            <div class="w-8 h-8 rounded-full bg-brand-green/20 flex items-center justify-center text-brand-green text-sm font-semibold">
              {user?.name?.charAt(0)?.toUpperCase() || 'U'}
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-white truncate">{user?.name || 'User'}</div>
              <div class="text-xs text-gray-400 truncate">{user?.role || 'operative'}</div>
            </div>
          </div>
          <form method="POST" action="/api/auth/sign-out" class="mt-3">
            <button
              type="submit"
              class="w-full text-left px-3 py-2 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-md transition-colors"
            >
              Sign Out
            </button>
          </form>
        </div>
      </aside>

      <!-- Main content -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Offline/sync banner -->
        <OfflineBanner client:load />

        <!-- Top bar (mobile) -->
        <header class="md:hidden flex items-center justify-between bg-white border-b border-gray-200 px-4 py-3">
          <div class="flex items-center gap-2">
            <img src="/images/Icons/Stacked.png" alt="Maintain London" class="h-8 w-auto" />
            <span class="text-sm font-semibold text-gray-900">Project Hub</span>
          </div>
          <div class="w-8 h-8 rounded-full bg-brand-green/20 flex items-center justify-center text-brand-green text-sm font-semibold">
            {user?.name?.charAt(0)?.toUpperCase() || 'U'}
          </div>
        </header>

        <!-- Page content -->
        <main class="flex-1 overflow-y-auto p-4 md:p-6 lg:p-8">
          <slot />
        </main>

        <!-- Bottom tab bar (mobile) -->
        <nav class="md:hidden flex items-center justify-around bg-white border-t border-gray-200 py-2">
          <a
            href="/project-hub/"
            class:list={[
              'flex flex-col items-center gap-1 px-3 py-1 text-xs',
              currentPath === '/project-hub/' || currentPath === '/project-hub'
                ? 'text-brand-green'
                : 'text-gray-400',
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
            </svg>
            Dashboard
          </a>
          <a
            href="/project-hub/settings"
            class:list={[
              'flex flex-col items-center gap-1 px-3 py-1 text-xs',
              currentPath.startsWith('/project-hub/settings')
                ? 'text-brand-green'
                : 'text-gray-400',
            ]}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
            </svg>
            Settings
          </a>
        </nav>
      </div>
    </div>
    <!-- Service Worker Registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js', { scope: '/project-hub/' })
            .catch(() => {});
        });
      }
    </script>
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    padding: 0;
    font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  .font-display {
    font-family: 'Inter Variable', system-ui, sans-serif;
  }
</style>
